{
  "name": "@figma-mcp-free/server",
  "version": "0.1.0",
  "description": "Read-only MCP server backed by the public Figma REST API",
  "type": "module",
  "files": ["dist", "README.md", "LICENSE"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": { "node": ">=18" },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superdoccimo/figma-mcp-free.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/superdoccimo/figma-mcp-free#readme",
  "bugs": { "url": "https://github.com/superdoccimo/figma-mcp-free/issues" },
  "keywords": ["figma", "mcp", "model-context-protocol", "rest-api", "read-only"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@figma-mcp-free/config": "workspace:*",
    "@figma-mcp-free/code-generator": "workspace:*",
    "@figma-mcp-free/design-tokens": "workspace:*",
    "@figma-mcp-free/figma-client": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^18",
    "ts-node": "^10.9.2",
    "tsx": "^4",
    "typescript": "^5.4"
  }
}
